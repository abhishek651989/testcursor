<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ticket Portal</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="topbar">
      <div class="topbar-left">
        <span class="app-title">Ticket Portal</span>
      </div>
      <% if (currentUser) { %>
      <div class="topbar-right">
        <span class="user-info">Signed in as <strong><%= currentUser.username %></strong></span>
        <form method="post" action="/logout">
          <button type="submit" class="btn btn-secondary">Logout</button>
        </form>
      </div>
      <% } %>
    </header>

    <main class="main">
      <%- body %>
    </main>

    <footer class="footer">
      <span>Simple Ticket Portal</span>
    </footer>
  </body>
  </html>

